{
  "manifest_version": 3,
  "name": "Free Dark Mode",
  "version": "0.2.0",
  "description": "A privacy-first, local-only dark mode extension.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Free Dark Mode",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16-16.png",
    "48": "icons/icon48-48.png",
    "128": "icons/icon128-128.png"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_start"
    }
  ]
}
